#!/bin/bash
# Workspace setup script for work repositories
# Sets up an isolated workspace with a unique database and Caddy config.
# All project-level env config (Redis, Elasticsearch, secrets, etc.) must be
# provided via a symlinked .env from your project's Stow package (e.g. caren-local).

set -e

echo "=== Work Workspace Setup ==="
echo ""

# Detect project type
if [ ! -f "config/database.yml" ] || [ ! -f "Gemfile" ]; then
  echo "ERROR: This script is designed for Rails projects"
  exit 1
fi
echo "Detected Rails project"

# Detect project name and workspace name
REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="$(dirname "$REPO_ROOT")"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
WORKSPACE_RAW="$(basename "$PWD")"
WORKSPACE_NAME="$(echo "$WORKSPACE_RAW" | tr '-' '_')"

echo "Project: ${PROJECT_NAME}"
echo "Workspace: ${WORKSPACE_NAME}"

# Calculate workspace-specific database name
PRIMARY_DB_NAME="${PROJECT_NAME}_${WORKSPACE_NAME}_development"
echo "Primary database: ${PRIMARY_DB_NAME}"

# Verify CONDUCTOR_PORT is set
if [ -z "$CONDUCTOR_PORT" ]; then
  echo "ERROR: CONDUCTOR_PORT is not set"
  echo "This script must be run from Conductor or with CONDUCTOR_PORT exported"
  exit 1
fi
echo "Conductor port: ${CONDUCTOR_PORT}"
echo ""

# Stow project-local config (.env, master.key, etc.) into this workspace
STOW_PACKAGE="${PROJECT_NAME}-local"
STOW_SOURCE="${HOME}/Developer/${PROJECT_NAME}"

echo "Running Stow (${STOW_PACKAGE})..."
if [ -d "${STOW_SOURCE}/${STOW_PACKAGE}" ]; then
  if command -v stow >/dev/null 2>&1; then
    stow -d "${STOW_SOURCE}" -t "$PWD" "${STOW_PACKAGE}"
    echo "✓ Stow package applied: ${STOW_PACKAGE}"
  else
    echo "ERROR: stow is not installed"
    echo "Install with: brew install stow"
    exit 1
  fi
else
  echo "WARNING: Stow package not found at ${STOW_SOURCE}/${STOW_PACKAGE}"
  echo "Create it with your .env, config/master.key, etc."
  echo "Continuing — db:prepare will likely fail without credentials."
fi
echo ""

# Check MySQL is available
echo "Checking services..."
if ! mysql -h 127.0.0.1 -u root -e "SELECT 1" >/dev/null 2>&1; then
  echo "ERROR: Cannot connect to MySQL."
  echo ""
  echo "Start Docker services:"
  echo "  cd ~/Developer/${PROJECT_NAME} && docker compose up -d"
  echo ""
  exit 1
fi
echo "✓ MySQL is available"

# Check Redis (warning only)
if ! redis-cli -h 127.0.0.1 ping >/dev/null 2>&1; then
  echo "WARNING: Cannot connect to Redis. Some features may not work."
else
  echo "✓ Redis is available"
fi
echo ""

# Generate .env.local with workspace-specific overrides only.
# Everything else (DB host/user/pass, Redis, Elasticsearch, CUPIDO, etc.)
# must live in the project's symlinked .env (e.g. via caren-local Stow package).
echo "Generating .env.local..."
cat > .env.local << EOF
# Conductor workspace configuration — workspace-specific overrides only.
# Generated by work/setup. Do not edit manually.
# All other config comes from the project-level .env (symlinked via Stow).

PORT=${CONDUCTOR_PORT}
DB_MYSQL_DATABASE=${PRIMARY_DB_NAME}
EOF

echo "✓ Generated .env.local"
echo ""

# Generate Caddy configuration
CADDY_CONFIG_DIR="${HOME}/.config/caddy"
CADDY_CONFIG_FILE="${CADDY_CONFIG_DIR}/${WORKSPACE_NAME}-${PROJECT_NAME}.caddy"

echo "Generating Caddy configuration..."
mkdir -p "$CADDY_CONFIG_DIR"

cat > "$CADDY_CONFIG_FILE" << EOF
${WORKSPACE_RAW}.${PROJECT_NAME}.localhost {
  reverse_proxy localhost:${CONDUCTOR_PORT} {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }
}
EOF

echo "✓ Generated Caddy config: ${CADDY_CONFIG_FILE}"
echo ""

# Install dependencies
echo "Installing dependencies..."
if [ -f "Gemfile.lock" ]; then
  bundle install --quiet
else
  bundle install
fi
echo ""

# Setup database
echo "Setting up database..."
set -a
# shellcheck source=/dev/null
source .env.local
set +a

if bundle exec rails db:version >/dev/null 2>&1; then
  echo "Database already exists: ${PRIMARY_DB_NAME}"
else
  echo "Creating database: ${PRIMARY_DB_NAME}"
  bundle exec rails db:prepare
fi
echo ""

# Reload Caddy configuration
echo "Reloading Caddy configuration..."
if command -v caddy >/dev/null 2>&1; then
  if caddy reload >/dev/null 2>&1; then
    echo "✓ Caddy reloaded successfully"
  else
    echo "warning: Failed to reload Caddy" >&2
    echo "Reload manually: caddy reload" >&2
  fi
else
  echo "warning: Caddy not found" >&2
fi
echo ""

echo "=== Setup Complete ==="
echo ""
echo "Next steps:"
echo "  1. Start the server: conductor/.config/conductor/scripts/work/run"
echo "  2. Access workspace at: https://${WORKSPACE_RAW}.${PROJECT_NAME}.localhost"
echo ""
echo "Database: ${PRIMARY_DB_NAME}"
echo "Port: ${CONDUCTOR_PORT}"
echo ""
