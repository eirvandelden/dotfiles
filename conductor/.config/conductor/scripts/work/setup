#!/bin/bash
# Workspace setup script for work repositories with slicing integration
# This script sets up isolated workspaces that use slicing Docker services

set -e

echo "=== Work Workspace Setup ==="
echo ""

# Detect project type
RAILS_PROJECT=false
if [ -f "config/database.yml" ] && [ -f "Gemfile" ]; then
  RAILS_PROJECT=true
  echo "Detected Rails project"
else
  echo "ERROR: This script is designed for Rails projects with slicing integration"
  exit 1
fi

# Detect project name and workspace name
REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="$(dirname "$REPO_ROOT")"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
WORKSPACE_RAW="$(basename "$PWD")"
WORKSPACE_NAME="$(echo "$WORKSPACE_RAW" | tr '-' '_')"

echo "Project: ${PROJECT_NAME}"
echo "Workspace: ${WORKSPACE_NAME}"

# Calculate database names
PRIMARY_DB_NAME="${PROJECT_NAME}_${WORKSPACE_NAME}_development"
echo "Primary database: ${PRIMARY_DB_NAME}"

# For caren, we also have a shared caren2 replica database
if [ "$PROJECT_NAME" = "caren" ]; then
  REPLICA_DB_NAME="caren_development"
  echo "Replica database (shared): ${REPLICA_DB_NAME}"
fi

# Verify CONDUCTOR_PORT is set
if [ -z "$CONDUCTOR_PORT" ]; then
  echo "ERROR: CONDUCTOR_PORT is not set"
  echo "This script must be run from Conductor or with CONDUCTOR_PORT exported"
  exit 1
fi
echo "Conductor port: ${CONDUCTOR_PORT}"
echo ""

# Check slicing MySQL is available
echo "Checking slicing services..."
if ! mysql -h localhost -u root -e "SELECT 1" >/dev/null 2>&1; then
  echo "ERROR: Cannot connect to MySQL. Is slicing running?"
  echo ""
  echo "Start slicing services:"
  echo "  cd ~/Developer/slicing && docker compose up -d mysql redis rabbitmq"
  echo ""
  exit 1
fi
echo "✓ MySQL is available"

# Check Redis (warning only)
if ! redis-cli -h localhost ping >/dev/null 2>&1; then
  echo "WARNING: Cannot connect to Redis. Some features may not work."
  echo "Start slicing: cd ~/Developer/slicing && docker compose up -d redis"
else
  echo "✓ Redis is available"
fi
echo ""

# Run worktree-setup for project-local configuration
echo "Running worktree-setup..."
if command -v worktree-setup >/dev/null 2>&1; then
  worktree-setup
elif [ -x "${HOME}/.config/git/worktree-tools/worktree-setup" ]; then
  "${HOME}/.config/git/worktree-tools/worktree-setup"
else
  echo "warning: worktree-setup not found, skipping generic setup" >&2
fi
echo ""

# Generate .env.local with workspace-specific configuration
echo "Generating .env.local..."
cat > .env.local << EOF
# Conductor workspace configuration
# Generated by work/setup script

# Use docker Rails environment for dynamic database configuration
RAILS_ENV=docker

# Port configuration
PORT=${CONDUCTOR_PORT}

# Primary database configuration
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_USERNAME=root
DB_MYSQL_PASSWORD=
DB_MYSQL_DATABASE=${PRIMARY_DB_NAME}
EOF

# Add caren2 replica configuration for caren project
if [ "$PROJECT_NAME" = "caren" ]; then
  cat >> .env.local << EOF

# Caren2 replica database (shared across workspaces)
DB_CAREN2_MYSQL_DATABASE=${REPLICA_DB_NAME}
DB_CAREN2_MYSQL_HOST=localhost
DB_CAREN2_MYSQL_PORT=3306
DB_CAREN2_MYSQL_USERNAME=root
DB_CAREN2_MYSQL_PASSWORD=
EOF
fi

# Add slicing service URLs
cat >> .env.local << EOF

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STORE_SSL=false
REDIS_CACHE_SSL=false

# RabbitMQ (Cupido)
CUPIDO_AMQP_HOST=localhost
CUPIDO_AMQP_SUBSCRIBE_ADDRESSES=localhost:5672
CUPIDO_AMQP_PUBLISH_ADDRESSES=localhost:5672
CUPIDO_AMQP_SUBSCRIBE_PORT=5672
CUPIDO_AMQP_PUBLISH_PORT=5672
CUPIDO_AMQP_USER=guest
CUPIDO_AMQP_PASSWORD=guest
CUPIDO_AMQP_VHOST=/
CUPIDO_AMQP_DURABLE=true

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=HZd4FY9RFEtq3e

# Environment
ENVIRONMENT=local
TZ=Europe/Amsterdam
EOF

echo "✓ Generated .env.local"
echo ""

# Generate Caddy configuration
CADDY_CONFIG_DIR="${HOME}/.config/caddy"
CADDY_CONFIG_FILE="${CADDY_CONFIG_DIR}/${WORKSPACE_NAME}-${PROJECT_NAME}.caddy"

echo "Generating Caddy configuration..."
mkdir -p "$CADDY_CONFIG_DIR"

cat > "$CADDY_CONFIG_FILE" << EOF
${WORKSPACE_RAW}.${PROJECT_NAME}.localhost {
  reverse_proxy localhost:${CONDUCTOR_PORT} {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }
}
EOF

echo "✓ Generated Caddy config: ${CADDY_CONFIG_FILE}"
echo ""

# Load secrets from 1Password
if command -v unlock >/dev/null 2>&1; then
  echo "Loading secrets from 1Password..."
  eval "$(unlock)" || {
    echo "warning: Failed to load secrets from 1Password" >&2
    echo "Continuing anyway - you may need to set secrets manually" >&2
  }
elif command -v secrets >/dev/null 2>&1; then
  echo "Loading secrets..."
  eval "$(secrets)" || {
    echo "warning: Failed to load secrets" >&2
    echo "Continuing anyway - you may need to set secrets manually" >&2
  }
else
  echo "Note: No 'unlock' or 'secrets' command found"
  echo "If you need JFrog tokens or other secrets, set them up manually"
fi
echo ""

# Install dependencies
echo "Installing dependencies..."
if [ -f "Gemfile.lock" ]; then
  bundle install --quiet
else
  echo "No Gemfile.lock found, running bundle install for the first time..."
  bundle install
fi
echo ""

# Setup database
echo "Setting up database..."
# Source .env.local to get RAILS_ENV and database config
set -a
# shellcheck source=/dev/null
source .env.local
set +a

if bundle exec rails db:version >/dev/null 2>&1; then
  echo "Database already exists: ${PRIMARY_DB_NAME}"
else
  echo "Creating database: ${PRIMARY_DB_NAME}"
  bundle exec rails db:prepare
fi
echo ""

# Reload Caddy configuration
echo "Reloading Caddy configuration..."
if command -v caddy >/dev/null 2>&1; then
  if caddy reload >/dev/null 2>&1; then
    echo "✓ Caddy reloaded successfully"
  else
    echo "warning: Failed to reload Caddy" >&2
    echo "You may need to reload Caddy manually: caddy reload" >&2
  fi
else
  echo "warning: Caddy not found" >&2
  echo "Install Caddy or reload it manually after starting" >&2
fi
echo ""

echo "=== Setup Complete ==="
echo ""
echo "Next steps:"
echo "  1. Start the server: ../dotfiles/cancun/conductor/.config/conductor/scripts/work/run"
echo "  2. Access workspace at: https://${WORKSPACE_RAW}.${PROJECT_NAME}.localhost"
echo ""
echo "Database: ${PRIMARY_DB_NAME}"
echo "Port: ${CONDUCTOR_PORT}"
echo ""
