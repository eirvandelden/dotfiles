#!/bin/bash
# Workspace archive script for Conductor
# This script is called before removing a workspace to clean up resources

set -e

load_env_local() {
  if [ -f ".env.local" ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env.local
    set +a
  fi
}

workspace_name() {
  if [ -n "${CONDUCTOR_WORKSPACE_NAME:-}" ]; then
    printf '%s\n' "${CONDUCTOR_WORKSPACE_NAME}"
  else
    basename "$PWD"
  fi
}

repo_root_path() {
  git worktree list | awk 'NR==1{print $1}'
}

workspace_database_name() {
  local worktree_name repo_root project_name
  worktree_name="$(workspace_name)"
  repo_root="$(repo_root_path)"
  project_name="$(basename "${repo_root}")"
  printf '%s\n' "${project_name}_${worktree_name}_development"
}

load_database_name() {
  load_env_local

  if [ -z "${DATABASE_NAME:-}" ]; then
    DATABASE_NAME="$(workspace_database_name)"
    export DATABASE_NAME
  fi
}

echo "=== Workspace Archive ==="
echo ""

# Check if this is a Rails project with database
if [ -f "config/database.yml" ] && [ -f "Gemfile" ]; then
  echo "Detected Rails project"

  load_database_name

  echo ""
  echo "Dropping database: ${DATABASE_NAME}"

  # Try to drop the database, but don't fail if it doesn't exist
  if bundle exec rails db:drop 2>/dev/null; then
    echo "Database dropped successfully"
  else
    echo "warning: Could not drop database (it may not exist)" >&2
  fi
fi

# Run worktree-remove to clean up puma-dev, Caddy config, and stow symlinks
echo ""
echo "Running worktree-remove..."
if command -v worktree-remove >/dev/null 2>&1; then
  worktree-remove "$PWD"
elif [ -x "${HOME}/.config/git/worktree-tools/worktree-remove" ]; then
  "${HOME}/.config/git/worktree-tools/worktree-remove" "$PWD"
else
  echo "warning: worktree-remove not found, skipping worktree cleanup" >&2
fi

echo ""
echo "=== Archive Complete ==="
